#!/usr/bin/env Rscript
###############################################################
# AgWise Bias Correction & Statistical Downscaling Module
# =======================================================
#
# Concept
# -------
# This script performs bias correction and statistical downscaling
# of subseasonal–seasonal (S2S) or seasonal forecast data within the
# AgWise / AgWISE_Forecast workflow. It uses:
#
#   - Historical hindcast data to learn systematic model biases
#     relative to high-quality reference observations, and
#   - Applies the derived correction to real-time or target-year
#     forecasts to produce bias-adjusted, analysis-ready fields.
#
# The workflow is designed around:
#
#   * Scientific transparency:
#       - Explicit use of hindcasts for calibration only.
#       - Clearly defined reference period and spatial domain.
#   * Consistency across variables and models:
#       - Common folder structure shared with the Python
#         AgWise_Download module.
#       - Unified handling of multiple variables
#         (e.g. PRCP, TMAX, TMIN, TEMP, SRAD).
#   * Operational readiness:
#       - Inputs are taken from standardized "raw" directories
#         (obs + model files generated by Python).
#       - Outputs are written to "processed" directories, separated
#         by country, variable, and forecast year.
#
# Core logic
# ----------
# 1. Read country-specific configuration from 00_config_<COUNTRY>.R,
#    including:
#       - Base directories and country code
#       - Raw and processed folder paths
#       - Calibration years (hindcast period)
#       - Spatial domain (lon/lat limits)
#
# 2. For each variable of interest (e.g. PRCP, TMAX, TMIN, TEMP, SRAD):
#       - Load observation time series for the calibration period.
#       - Load hindcast model data for the same period.
#       - Load corresponding real-time forecasts to be corrected.
#
# 3. Perform bias correction / statistical downscaling:
#       - Estimate biases using hindcasts vs observations.
#       - Apply quantile delta mapping (QDM) or similar method
#         to the forecast data, treating hindcasts only as the
#         calibration set.
#
# 4. Export bias-corrected forecasts:
#       - Save corrected forecast fields as NetCDF in a consistent
#         naming convention under:
#           processed/bias_corrected/forecast/
#       - Optionally generate spatial bias maps for diagnostic
#         purposes (hindcast vs obs, and bias-corrected forecast).
#
# Intended use
# ------------
# This module serves as the R-based post-processing layer for
# AgWise / AgWISE_Forecast and related national agro-climate
# advisory systems. It bridges raw model output and downstream
# applications such as:
#
#   - Agro-climate indices and extremes,
#   - Crop and livestock models (e.g. DSSAT),
#   - Advisory products and decision-support tools,
#   - Skill assessment and verification workflows.
#
# Author
# ------
# Jemal Seid Ahmed, Wuletaw Abera
# Alliance of Bioversity International & CIAT (CGIAR)
# Email: jemal.ahmed@cgiar.org
#
# Date: July 2025
# Version: 1.5
###############################################################

# TODO: This needs to be read automatically
# Same as in 02_*.py
lonLim <- c(33.5 , 42.0)
latLim <- c(-4.7, 5.5)
# latLim <- c(-0.425, 0.075)
# lonLim <- c(34.375, 35.750)
years_obs <- 1985:2024
years_calib <- 2014:2015
forecast_years <- c(2025, 2025)

options(java.parameters = "-Xmx64g")

###############################################################
# Load required libraries
###############################################################
library(ncdf4)
library(terra)
library(loadeR)
library(transformeR)
library(downscaleR)
library(loadeR.2nc)
library(visualizeR)
library(parallel)
library(gridExtra)

###############################################################
# 1. Source country configuration (paths & domain)
###############################################################
## Switch this for other countries: 00_config_ETH.R, etc.
source("/home/jovyan/agwise-planting-date-and-cultivar/Data/useCase_Kenya_KALRO_app2/Maize/Forecast/python/00_config_KEN.R")


###############################################################
# 2. Variable configuration (AgWise obs + S2S models)
###############################################################
VAR_CONFIG <- list(
  PRCP = list(
    obs_file_pattern = "Daily_PRCP_%d_%d.nc",
    obs_var          = "Precipitation_Flux",          # from AgWise_AgroIndicators (AGRO.PRCP)
    model_var        = "tp",         # from AgWise_Download_Models_Daily
    is_precip        = TRUE,
    scaling.type     = "multiplicative",
    units            = "mm/day",
    brks_bias        = seq(-7, 7, by = 1)
  ),
  TMAX = list(
    obs_file_pattern = "Daily_TMAX_%d_%d.nc",
    obs_var          = "Temperature_Air_2m_Max_24h",
    model_var        = "mx2t24",
    is_precip        = FALSE,
    scaling.type     = "additive",
    units            = "degC",
    brks_bias        = seq(-4, 4, by = 0.5)
  ),
  TMIN = list(
    obs_file_pattern = "Daily_TMIN_%d_%d.nc",
    obs_var          = "Temperature_Air_2m_Min_24h",
    model_var        = "mn2t24",
    is_precip        = FALSE,
    scaling.type     = "additive",
    units            = "degC",
    brks_bias        = seq(-4, 4, by = 0.5)
  ),
  TEMP = list(
    obs_file_pattern = "Daily_TEMP_%d_%d.nc",
    obs_var          = "Temperature_Air_2m_Mean_24h",
    model_var        = "",
    is_precip        = FALSE,
    scaling.type     = "additive",
    units            = "degC",
    brks_bias        = seq(-4, 4, by = 0.5)
  ),
  SRAD = list(
    obs_file_pattern = "Daily_SRAD_%d_%d.nc",
    obs_var          = "Solar_Radiation_Flux",
    model_var        = "ssrd",
    is_precip        = FALSE,
    scaling.type     = "multiplicative",
    units            = "MJ/m2/day",                   # Python already J→MJ
    brks_bias        = seq(-6, 6, by = 0.5)
  )
)

## Variables to process
variables_to_bc <- c("PRCP", "TMAX", "TMIN", "TEMP", "SRAD")
variables_to_bc <- intersect(variables_to_bc, names(VAR_CONFIG))

if (length(variables_to_bc) == 0) {
  stop("No valid variables selected for bias correction.")
}

#############################################################
# 2 Run Python multi-country downloader BEFORE bias correction
###############################################################

message("Running AgWise Python downloader for country: ", country_code)

# Build the system command
py_script <- file.path(base_dir, "python", "02_run_agwise_multi_country.py")

# cmd <- sprintf("python %s --countries %s", py_script, country_code)
cmd <- sprintf("/opt/conda/bin/python %s --countries %s", py_script, country_code)

# Execute command
status <- system(cmd, intern = TRUE)

message("Python downloader output:")
print(status)

message("Downloader finished. Proceeding to bias correction...")


###############################################################
# 4. Parallel setting INSIDE biasCorrection
###############################################################
n_cores <- max(1, detectCores() - 1)

###############################################################
# 4. Loop over variables: PRCP, TMAX, TMIN, TEMP, SRAD, ...
###############################################################


for (var_code in variables_to_bc) {
  
  cfg <- VAR_CONFIG[[var_code]]
  message("===================================================")
  message("Variable: ", var_code)
  message(" -> obs_file_pattern: ", cfg$obs_file_pattern)
  message(" -> obs_var: ", cfg$obs_var, " | model_var: ", cfg$model_var)
  
  ###########################################################
  # 4.1 Observation file (from Python AgWise_AgroIndicators)
  ###########################################################
  obs_year_start <- min(years_obs)  # TODO: Changed from min(years_calib)
  obs_year_end <- max(years_obs)  # TODO: Changed from max(years_calib)
  
  obs_file <- file.path(
    dir_obs_raw,
    sprintf(cfg$obs_file_pattern, obs_year_start, obs_year_end)
  )
  
  if (!file.exists(obs_file)) {
    message("  !! Obs file not found, skipping variable ", var_code, ": ", obs_file)
    next
  }
  
  ###########################################################
  # 4.2 Hindcast & forecast files for this variable
  #     Python naming:
  #       hindcast_<modelid>_<VAR>_...
  #       forecast_<modelid>_<VAR>_...
  ###########################################################
  hind_pattern <- sprintf("^hindcast_.*_%s_.*\\.nc$", var_code)
  fcst_pattern <- sprintf("^forecast_.*_%s_.*\\.nc$", var_code)
  
  hind_files <- list.files(
    dir_mod_raw,
    pattern = hind_pattern,
    full.names = TRUE
  )
  fcst_files <- list.files(
    dir_mod_raw,
    pattern = fcst_pattern,
    full.names = TRUE
  )
  
  if (length(hind_files) == 0) {
    message("  !! No hindcast files for ", var_code, " in: ", dir_mod_raw)
    next
  }
  if (length(fcst_files) == 0) {
    message("  !! No forecast files for ", var_code, " in: ", dir_mod_raw)
    next
  }
  
  ## Extract model IDs (e.g. "ecmwf51") so we can pair hindcast + forecast
  hind_ids <- sub("^hindcast_([^_]+)_.+\\.nc$", "\\1", basename(hind_files))
  fcst_ids <- sub("^forecast_([^_]+)_.+\\.nc$", "\\1", basename(fcst_files))
  
  model_ids <- intersect(unique(hind_ids), unique(fcst_ids))
  if (length(model_ids) == 0) {
    message("  !! No common model IDs between hindcast and forecast for ", var_code)
    next
  }
  
  ###########################################################
  # 4.3 Load observed calibration data (reference)
  ###########################################################
  nc_obs <- loadGridData(
    dataset = obs_file,
    var = cfg$obs_var, # "Precipitation_Flux", #cfg$obs_var,
    lonLim = lonLim,
    latLim = latLim,
    years = years_calib
  )
  attr(nc_obs$Variable, "units") <- cfg$units
  obs_clim <- climatology(nc_obs)
  
  ###########################################################
  # 4.4 Loop over models that have both hindcast & forecast
  ###########################################################
  for (m in model_ids) {
    
    message("---------------------------------------------------")
    message("Processing ", var_code, " for model ID: ", m)
    
    ## Select matching hindcast & forecast files
    hind_file <- hind_files[hind_ids == m][1]
    fcst_file <- fcst_files[fcst_ids == m][1]
    
    message("  Hindcast file: ", hind_file)
    message("  Forecast file: ", fcst_file)
    
    if (!file.exists(hind_file) || !file.exists(fcst_file)) {
      message("  -> Hindcast or forecast file missing, skipping model ", m)
      next
    }
    
    #--------------------------------------------------------
    # 4.4.1 Load hindcast (calibration) data
    #--------------------------------------------------------
    nc_hind <- tryCatch({
      loadGridData(
        dataset = hind_file,
        var     = cfg$model_var,
        lonLim  = lonLim,
        latLim  = latLim,
        years   = 2014:2015
      )
    }, error = function(e) {
      message("  Failed to load hindcast: ", hind_file)
      message("  Error: ", e$message)
      return(NULL)
    })
    
    if (is.null(nc_hind)) {
      message("  -> Hindcast load returned NULL, skipping model ", m)
      next
    }
    
    #--------------------------------------------------------
    # 4.4.2 Load forecast data (to be bias-corrected)
    #--------------------------------------------------------
    nc_fcst <- tryCatch({
      loadGridData(
        dataset = fcst_file,
        var     = cfg$model_var,
        lonLim  = lonLim,
        latLim  = latLim
        ## Usually forecast years are a single init year; we can
        ## keep all available times, so we skip 'years=' here.
      )
    }, error = function(e) {
      message("  Failed to load forecast: ", fcst_file)
      message("  Error: ", e$message)
      return(NULL)
    })
    
    if (is.null(nc_fcst)) {
      message("  -> Forecast load returned NULL, skipping model ", m)
      next
    }
    
    #--------------------------------------------------------
    # 4.4.3 Bias correction: hindcast calibrates, forecast is newdata
    #     y       = obs (calibration period)
    #     x       = hindcast model (calibration period)
    #     newdata = forecast model (to correct)
    #--------------------------------------------------------
    message("  -> Running biasCorrection (hindcast→forecast)...")
    
    # Error with months not being the same
    common_months <- 2:9
    nc_obs  <- subsetGrid(nc_obs,  
                          season = common_months)
    nc_hind <- subsetGrid(nc_hind, 
                          season = common_months)
    nc_fcst <- subsetGrid(nc_fcst, 
                          season = common_months)
    
    
    nc_fcst_bc <- biasCorrection(
      y             = nc_obs,
      x             = nc_hind,
      newdata       = nc_fcst,
      precipitation = cfg$is_precip,
      method        = "qdm",
      cross.val     = "none",
      consecutive   = cfg$is_precip,
      scaling.type  = cfg$scaling.type,
      max.ncores    = n_cores
    )
    
    #--------------------------------------------------------
    # 4.4.4 Export bias-corrected FORECAST only
    #--------------------------------------------------------
    ## Use model ID 'm' and forecast years for naming
    fcst_years_str <- paste(forecast_years, collapse = "-")
    
    outFile <- file.path(
      dir_bc_fcst,
      sprintf("%s_day_%s_forecast_BC_%s.nc",
              var_code, m, fcst_years_str)
    )
    
    message("  -> Writing bias-corrected FORECAST NetCDF: ", outFile)
    
    grid2nc(
      data          = nc_fcst_bc,
      NetCDFOutFile = outFile,
      missval       = -999,
      compression   = 3
    )
    
    #--------------------------------------------------------
    # 4.4.5 Bias maps (optional, still useful to check performance)
    #         Here we compare:
    #           - Hindcast climatology vs obs (raw bias)
    #           - Bias-corrected forecast climatology vs obs
    #         (strictly speaking, the latter is 'future' period, but
    #          this is still useful for sanity plotting—optional)
    #--------------------------------------------------------
    mask <- gridArithmetics(nc_obs, 0, operator = "*")
    
    ## Hindcast regridded to obs grid
    nc_hind_interp <- interpGrid(nc_hind, getGrid(nc_obs), ncores = n_cores)
    nc_hind_interp <- gridArithmetics(nc_hind_interp, mask, operator = "+")
    
    ## Bias-corrected forecast regridded to obs grid
    nc_fcst_bc_interp <- interpGrid(nc_fcst_bc, getGrid(nc_obs), ncores = n_cores)
    nc_fcst_bc_interp <- gridArithmetics(nc_fcst_bc_interp, mask, operator = "+")
    
    ## Climatologies
    hind_clim   <- climatology(nc_hind_interp)
    fcstbc_clim <- climatology(nc_fcst_bc_interp)
    
    ## Bias relative to obs climatology
    bias_hind  <- gridArithmetics(hind_clim,  obs_clim, operator = "-")
    bias_fcst  <- gridArithmetics(fcstbc_clim, obs_clim, operator = "-")
    
    brks <- cfg$brks_bias
    
    fig_file <- file.path(
      dir_fig_bias,
      sprintf("Bias_%s_%s.png", var_code, m)
    )
    message("  -> Saving bias map (hindcast & BC forecast): ", fig_file)
    
    png(fig_file, width = 1800, height = 800, res = 150)
    
    p1 <- spatialPlot(
      climatology(bias_hind),
      at   = brks, backdrop.theme = "countries",
      scales = list(draw = TRUE),
      main  = paste(m, var_code, "HINDCAST bias (model - obs) [", cfg$units, "]")
    )
    
    p2 <- spatialPlot(
      climatology(bias_fcst),
      at   = brks, backdrop.theme = "countries",
      scales = list(draw = TRUE),
      main  = paste(m, var_code, "BC FORECAST bias (model - obs) [", cfg$units, "]")
    )
    
    p3 <- spatialPlot(
      climatology(nc_obs),
      main = paste(country_name, var_code, "Observed climatology [", cfg$units, "]")
    )
    
    p4 <- spatialPlot(
      climatology(nc_hind),
      main = paste(m, var_code, "Hindcast climatology [", cfg$units, "]")
    )
    
    grid.arrange(p1, p2, p3, p4, ncol = 2)
    dev.off()
    
    #--------------------------------------------------------
    # 4.4.6 Clean up RAM
    #--------------------------------------------------------
    rm(nc_hind, nc_fcst, nc_fcst_bc,
       nc_hind_interp, nc_fcst_bc_interp,
       hind_clim, fcstbc_clim,
       bias_hind, bias_fcst,
       p1, p2, p3, p4)
    gc()
    
    message("  -> Finished ", var_code, " for model ID: ", m)
  }
}

message("All variables for this country (FORECASTS) bias-corrected.")
